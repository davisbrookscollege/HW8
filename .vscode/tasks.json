{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: build active file",
            "type": "shell",
            "command": "${workspaceFolder}\\.vscode\\build-active.bat",
            "args": [
                "${file}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Build the active C++ file with MSVC"
        },
        {
            "label": "C/C++: run active file",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/d",
                "/s",
                "/c",
                "\"${fileDirname}\\${fileBasenameNoExtension}.exe\""
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "dependsOn": "C/C++: build active file",
            "problemMatcher": []
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ]
}