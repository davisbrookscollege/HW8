{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C/C++: build project",
      "type": "shell",
      "command": "${workspaceFolder}\\.vscode\\build-active.bat",
      "args": [],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Build the project with MSVC into the build folder"
    },
    {
      "label": "C/C++: run project",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/d",
        "/s",
        "/c",
        "\"${workspaceFolder}\\build\\HW8.exe\""
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "C/C++: build project",
      "problemMatcher": []
    },
    {
      "label": "C/C++: clean build folder",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "if (Test-Path '${workspaceFolder}\\build') { Remove-Item '${workspaceFolder}\\build\\*' -Recurse -Force }"
      ],
      "problemMatcher": []
    }
  ]
}
